{
  "manifest_version": 3,
  "name": "TxLens",
  "version": "0.2",
  "description": "See what you sign before you sign it.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "TxLens"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}